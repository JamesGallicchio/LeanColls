c5f801ac/Mathlib/Order/CompleteLattice.lean#L311-L320","name":"CompleteLinearOrder","line":311,"kind":"class","docLink":"./Mathlib/Order/CompleteLattice.html#CompleteLinearOrder","doc":"A complete linear order is a linear order whose lattice structure is complete. "},"header":"<div class=\"decl_header\"><span class=\"decl_kind\">class</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./Mathlib/Order/CompleteLattice.html#CompleteLinearOrder\"><span class=\"name\">CompleteLinearOrder</span></a></span><span class=\"decl_args\">\n<span class=\"fn\">(α : <a href=\"./foundational_types.html\">Type</a> u_9)</span></span>\n<span class=\"decl_extends\">extends</span><span class=\"decl_parent\">\n<span class=\"fn\"><a class=\"break_within\" href=\"./Mathlib/Order/CompleteLattice.html#CompleteLattice\"><span class=\"name\">CompleteLattice</span></a></span></span>\n<span class=\"decl_args\"> :</span><div class=\"decl_type\"><a href=\"./foundational_types.html\">Type</a> u_9</div></div>"},{"info":{"sourceLink":"https://github.com/leanprover-community/mathlib4/blob/b5eba595428809e96f3ed113bc7ba776c5f801ac/Mathlib/Order/CompleteLattice.lean#L301-L303","name":"completeLatticeOfCompleteSemilatticeSup","line":301,"kind":"def","docLink":"./Mathlib/Order/CompleteLattice.html#completeLatticeOfCompleteSemilatticeSup","doc":"Any `CompleteSemilatticeSup` is in fact a `CompleteLattice`.\n\nNote that this construction has bad definitional properties:\nsee the doc-string on `completeLatticeOfSup`.\n"},"header":"<div class=\"decl_header\"><span class=\"decl_kind\">def</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./Mathlib/Order/CompleteLattice.html#completeLatticeOfCompleteSemilatticeSup\"><span class=\"name\">completeLatticeOfCompleteSemilatticeSup</span></a></span><span class=\"decl_args\">\n<span class=\"fn\">(α : <a href=\"./foundational_types.html\">Type</a> u_9)</span></span>\n<span class=\"impl_arg\"><span class=\"decl_args\">\n<span class=\"fn\">[<span class=\"fn\"><a href=\"./Mathlib/Order/CompleteLattice.html#CompleteSemilatticeSup\">CompleteSemilatticeSup</a> <span class=\"fn\">α</span></span>]</span></span>\n</span><span class=\"decl_args\"> :</span><div class=\"decl_type\"><span class=\"fn\"><a href=\"./Mathlib/Order/CompleteLattice.html#CompleteLattice\">CompleteLattice</a> <span class=\"fn\">α</span></span></div></div>"},{"info":{"sourceLink":"https://github.com/leanprover-community/mathlib4/blob/b5eba595428809e96f3ed113bc7ba776c5f801ac/Mathlib/Order/CompleteLattice.lean#L274-L293","name":"completeLatticeOfSup","line":274,"kind":"def","docLink":"./Mathlib/Order/CompleteLattice.html#completeLatticeOfSup","doc":"Create a `CompleteLattice` from a `PartialOrder` and `SupSet`\nthat returns the least upper bound of a set. Usually this constructor provides\npoor definitional equalities.  If other fields are known explicitly, they should be\nprovided; for example, if `inf` is known explicitly, construct the `CompleteLattice`\ninstance as\n```\ninstance : CompleteLattice my_T where\n  inf := better_inf\n  le_inf := ...\n  inf_le_right := ...\n  inf_le_left := ...\n  -- don't care to fix sup, sInf, bot, top\n  __ := completeLatticeOfSup my_T _\n```\n"},"header":"<div class=\"decl_header\"><span class=\"decl_kind\">def</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./Mathlib/Order/CompleteLattice.html#completeLatticeOfSup\"><span class=\"name\">completeLatticeOfSup</span></a></span><span class=\"decl_args\">\n<span class=\"fn\">(α : <a href=\"./foundational_types.html\">Type</a> u_9)</span></span>\n<span class=\"impl_arg\"><span class=\"decl_args\">\n<span class=\"fn\">[H1 : <span class=\"fn\"><a href=\"./Mathlib/Init/Order/Defs.html#PartialOrder\">PartialOrder</a> <span class=\"fn\">α</span></span>]</span></span>\n</span><span class=\"impl_arg\"><span class=\"decl_args\">\n<span class=\"fn\">[H2 : <span class=\"fn\"><a href=\"./Mathlib/Order/SetNotation.html#SupSet\">SupSet</a> <span class=\"fn\">α</span></span>]</span></span>\n</span><span class=\"decl_args\">\n<span class=\"fn\">(isLUB_sSup : <span class=\"fn\">∀ (<span class=\"fn\">s</span> : <span class=\"fn\"><a href=\"./Mathlib/Init/Set.html#Set\">Set</a> <span class=\"fn\">α</span></span>), <span class=\"fn\"><a href=\"./Mathlib/Order/Bounds/Basic.html#IsLUB\">IsLUB</a> <span class=\"fn\">s</span> <span class=\"fn\">(<span class=\"fn\"><a href=\"./Mathlib/Order/SetNotation.html#SupSet.sSup\">sSup</a> <span class=\"fn\">s</span></span>)</span></span></span>)</span></span>\n<span class=\"decl_args\"> :</span><div class=\"decl_type\"><span class=\"fn\"><a href=\"./Mathlib/Order/CompleteLattice.html#CompleteLattice\">CompleteLattice</a> <span class=\"fn\">α</span></span></div></div>"},{"info":{"sourceLink":"https://github.com/leanprover-community/mathlib4/blob/b5eba595428809e96f3ed113bc7ba776c5f801ac/Mathlib/Order/CompleteLattice.lean#L254-L256","name":"completeLatticeOfCompleteSemilatticeInf","line":254,"kind":"def","docLink":"./Mathlib/Order/CompleteLattice.html#completeLatticeOfCompleteSemilatticeInf","doc":"Any `CompleteSemilatticeInf` is in fact a `CompleteLattice`.\n\nNote that this construction has bad definitional properties:\nsee the doc-string on `completeLatticeOfInf`.\n"},"header":"<div class=\"decl_header\"><span class=\"decl_kind\">def</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./Mathlib/Order/CompleteLattice.html#completeLatticeOfCompleteSemilatticeInf\"><span class=\"name\">completeLatticeOfCompleteSemilatticeInf</span></a></span><span class=\"decl_args\">\n<span class=\"fn\">(α : <a href=\"./foundational_types.html\">Type</a> u_9)</span></span>\n<span class=\"impl_arg\"><span class=\"decl_args\">\n<span class=\"fn\">[<span class=\"fn\"><a href=\"./Mathlib/Order/CompleteLattice.html#CompleteSemilatticeInf\">CompleteSemilatticeInf</a> <span class=\"fn\">α</span></span>]</span></span>\n</span><span class=\"decl_args\"> :</span><div class=\"decl_type\"><span clas