prover-community/mathlib4/blob/b5eba595428809e96f3ed113bc7ba776c5f801ac/Mathlib/Algebra/Opposites.lean#L74-L75","name":"«term_ᵃᵒᵖ»","line":74,"kind":"def","docLink":"./Mathlib/Algebra/Opposites.html#«term_ᵃᵒᵖ»","doc":"Additive opposite of a type. "},"header":"<div class=\"decl_header\"><span class=\"decl_kind\">def</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./Mathlib/Algebra/Opposites.html#«term_ᵃᵒᵖ»\"><span class=\"name\">«term_ᵃᵒᵖ»</span></a></span><span class=\"decl_args\"> :</span><div class=\"decl_type\"><a href=\"./Init/Prelude.html#Lean.TrailingParserDescr\">Lean.TrailingParserDescr</a></div></div>"},{"info":{"sourceLink":"https://github.com/leanprover-community/mathlib4/blob/b5eba595428809e96f3ed113bc7ba776c5f801ac/Mathlib/Algebra/Opposites.lean#L71-L72","name":"«term_ᵐᵒᵖ»","line":71,"kind":"def","docLink":"./Mathlib/Algebra/Opposites.html#«term_ᵐᵒᵖ»","doc":"Multiplicative opposite of a type. "},"header":"<div class=\"decl_header\"><span class=\"decl_kind\">def</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./Mathlib/Algebra/Opposites.html#«term_ᵐᵒᵖ»\"><span class=\"name\">«term_ᵐᵒᵖ»</span></a></span><span class=\"decl_args\"> :</span><div class=\"decl_type\"><a href=\"./Init/Prelude.html#Lean.TrailingParserDescr\">Lean.TrailingParserDescr</a></div></div>"},{"info":{"sourceLink":"https://github.com/leanprover-community/mathlib4/blob/b5eba595428809e96f3ed113bc7ba776c5f801ac/Mathlib/Algebra/Opposites.lean#L64-L64","name":"MulOpposite","line":64,"kind":"def","docLink":"./Mathlib/Algebra/Opposites.html#MulOpposite","doc":"Multiplicative opposite of a type. This type inherits all additive structures on `α` and\nreverses left and right in multiplication. "},"header":"<div class=\"decl_header\"><span class=\"decl_kind\">def</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./Mathlib/Algebra/Opposites.html#MulOpposite\"><span class=\"name\">MulOpposite</span></a></span><span class=\"decl_args\">\n<span class=\"fn\">(α : <a href=\"./foundational_types.html\">Type</a> u_3)</span></span>\n<span class=\"decl_args\"> :</span><div class=\"decl_type\"><a href=\"./foundational_types.html\">Type</a> u_3</div></div>"},{"info":{"sourceLink":"https://github.com/leanprover-community/mathlib4/blob/b5eba595428809e96f3ed113bc7ba776c5f801ac/Mathlib/Algebra/Opposites.lean#L61-L63","name":"AddOpposite","line":61,"kind":"def","docLink":"./Mathlib/Algebra/Opposites.html#AddOpposite","doc":"Additive opposite of a type. This type inherits all multiplicative structures on `α` and\nreverses left and right in addition."},"header":"<div class=\"decl_header\"><span class=\"decl_kind\">def</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./Mathlib/Algebra/Opposites.html#AddOpposite\"><span class=\"name\">AddOpposite</span></a></span><span class=\"decl_args\">\n<span class=\"fn\">(α : <a href=\"./foundational_types.html\">Type</a> u_3)</span></span>\n<span class=\"decl_args\"> :</span><div class=\"decl_type\"><a href=\"./foundational_types.html\">Type</a> u_3</div></div>"},{"info":{"sourceLink":"https://github.com/leanprover-community/mathlib4/blob/b5eba595428809e96f3ed113bc7ba776c5f801ac/Mathlib/Algebra/Opposites.lean#L57-L57","name":"PreOpposite.unop'","line":57,"kind":"def","docLink":"./Mathlib/Algebra/Opposites.html#PreOpposite.unop'","doc":"The element of `α` represented by `x : PreOpposite α`. "},"header":"<div class=\"decl_header\"><span class=\"decl_kind\">abbrev</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./Mathlib/Algebra/Opposites.html#PreOpposite.unop'\"><span class=\"name\">PreOpposite</span>.<span class=\"name\">unop'</span></a></span><span class=\"impl_arg\"><span class=\"decl_args\">\n<span class=\"fn\">{α : <a href=\"./foundational_types.html\">Type</a> u_3}</span></span>\n</span><span class=\"decl_args\">\n<span class=\"fn\">(self : <span class=\"fn\"><a href=\"./Mathlib/Algebra/Opposites.html#PreOpposite\">PreOpposite</a> <span class=\"fn\">α</span></span>)</span></span>\n<span class=\"decl_args\"> :</span><div class=\"decl_type\"><span class=\"fn\">α</span></div></div>"},{"info":{"sourceLink":"https://github.com/leanprover-community/mathlib4/blob/b5eba595428809e96f3ed113bc7ba776c5f801ac/Mathlib/Algebra/Opposites.lean#L56-L56","name":"PreOpposite.op'","line":56,"kind":"ctor","docLink":"./Mathlib/Algebra/Opposites.html#PreOpposite.op'","doc":"The element of `PreOpposite α` that represents `x : α`. "},"header":"<div class=\"decl_header\"><span class=\"decl_kind\">constructor</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./Mathlib/Algebra/Opposites.html#PreOpposite.op'\"><span class=\"name\">PreOpposite</span>.<span class=\"name\">op'</span></a></span><span class=\"impl_arg\"><span class=\"decl_args\">\n<span class=\"fn\">{α : <a href=\"./foundational_types.html\">Type</a> u_3}</span></span>\n</span><span class=\"decl_args\">\n<span class=\"fn\">(unop' : <span class=\"fn\">α</span>)</span></span>\n<span class=\"decl_args\"> :</span><div class=\"decl_type\"><span class=\"fn\"><a href=\"./Mathlib/Algebra/Opposites.html#PreOpposite\">PreOpposite</a> <span class=\"fn\">α</span></span></div></div>"},{"info":{"sourceLink":"https://github.com/leanprover-community/mathlib4/blob/b5eba595428809e96f3ed113bc7ba776c5f801ac/Mathlib/Algebra/Opposites.lean#L55-L57","name":"PreOpposite","line":55,"kind":"structure","docLink":"./Mathlib/Algebra/Opposites.html#PreOpposite","doc":"Auxiliary type to implement `MulOpposite` and `AddOpposite`.\n\nIt turns out to be convenient to have `MulOpposite α = AddOpposite α` true by definition, in the\nsame way that it is convenient to have `Additive α = α`; this means that we also get the defeq\n`AddOpposite (Additive α) = MulOpposite α`, which is convenient when working with quotients.\n\nThis is a compromise between making `MulOpposite α = AddOpposite α = α` (what we had in Lean 3) and\nhaving no defeqs within those three types (which we had as of mathlib4#1036). "},"header":"<div class=\"decl_header\"><span class=\"decl_kind\">structure</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./Mathlib/Algebra/Opposites.html#PreOpposite\"><span class=\"name\">PreOpposite</span></a></span><span class=\"decl_args\">\n<span class=\"fn\">(α : <a href=\"./foundational_types.html\">Type</a> u_3)</span></span>\n<span class=\"decl_args\"> :</span><div class=\"decl_type\"><a href=\"./foundational_types.html\">Type</a> u_3</div></div>"}]}