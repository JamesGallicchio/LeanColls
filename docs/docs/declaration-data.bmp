thub.com/leanprover/lean4/blob/dca5da6b18d95ba75a16d5bcfb81fcb26705709a/src/Init/Prelude.lean#L1998-L1998","name":"Lean.firstFrontendMacroScope","link":"/LeanColls/docs/semantic/9817414057048567525.xml#","docLink":"/LeanColls/docs/Init/Prelude.html#Lean.firstFrontendMacroScope","doc":"First macro scope available for our frontend "},{"sourceLink":"https://github.com/leanprover/lean4/blob/dca5da6b18d95ba75a16d5bcfb81fcb26705709a/src/Init/Prelude.lean#L2000-L2002","name":"Lean.MonadRef","link":"/LeanColls/docs/semantic/3547712668704961911.xml#","docLink":"/LeanColls/docs/Init/Prelude.html#Lean.MonadRef","doc":""},{"sourceLink":"https://github.com/leanprover/lean4/blob/dca5da6b18d95ba75a16d5bcfb81fcb26705709a/src/Init/Prelude.lean#L2006-L2008","name":"Lean.instMonadRef","link":"/LeanColls/docs/semantic/5021370926824609033.xml#","docLink":"/LeanColls/docs/Init/Prelude.html#Lean.instMonadRef","doc":""},{"sourceLink":"https://github.com/leanprover/lean4/blob/dca5da6b18d95ba75a16d5bcfb81fcb26705709a/src/Init/Prelude.lean#L2010-L2013","name":"Lean.replaceRef","link":"/LeanColls/docs/semantic/7398094282883011891.xml#","docLink":"/LeanColls/docs/Init/Prelude.html#Lean.replaceRef","doc":""},{"sourceLink":"https://github.com/leanprover/lean4/blob/dca5da6b18d95ba75a16d5bcfb81fcb26705709a/src/Init/Prelude.lean#L2015-L2018","name":"Lean.withRef","link":"/LeanColls/docs/semantic/15383426096281266899.xml#","docLink":"/LeanColls/docs/Init/Prelude.html#Lean.withRef","doc":""},{"sourceLink":"https://github.com/leanprover/lean4/blob/dca5da6b18d95ba75a16d5bcfb81fcb26705709a/src/Init/Prelude.lean#L2028-L2043","name":"Lean.MonadQuotation","link":"/LeanColls/docs/semantic/17431967815716861113.xml#","docLink":"/LeanColls/docs/Init/Prelude.html#Lean.MonadQuotation","doc":"A monad that supports syntax quotations. Syntax quotations (in term\n    position) are monadic values that when executed retrieve the current \"macro\n    scope\" from the monad and apply it to every identifier they introduce\n    (independent of whether this identifier turns out to be a reference to an\n    existing declaration, or an actually fresh binding during further\n    elaboration). We also apply the position of the result of `getRef` to each\n    introduced symbol, which results in better error positions than not applying\n    any position. "},{"sourceLink":"https://github.com/leanprover/lean4/blob/dca5da6b18d95ba75a16d5bcfb81fcb26705709a/src/Init/Prelude.lean#L2047-L2048","name":"Lean.MonadRef.mkInfoFromRefPos","link":"/LeanColls/docs/semantic/10545846489816252281.xml#","docLink":"/LeanColls/docs/Init/Prelude.html#Lean.MonadRef.mkInfoFromRefPos","doc":""},{"sourceLink":"https://github.com/leanprover/lean4/blob/dca5da6b18d95ba75a16d5bcfb81fcb26705709a/src/Init/Prelude.lean#L2050-L2053","name":"Lean.instMonadQuotation","link":"/LeanColls/docs/semantic/3435522609680447271.xml#","docLink":"/LeanColls/docs/Init/Prelude.html#Lean.instMonadQuotation","doc":""},{"sourceLink":"https://github.com/leanprover/lean4/blob/dca5da6b18d95ba75a16d5bcfb81fcb26705709a/src/Init/Prelude.lean#L2076-L2079","name":"Lean.Name.hasMacroScopes","link":"/LeanColls/docs/semantic/5734167616164134465.xml#","docLink":"/LeanColls/docs/Init/Prelude.html#Lean.Name.hasMacroScopes","doc":""},{"sourceLink":"https://github.com/leanprover/lean4/blob/dca5da6b18d95ba75a16d5bcfb81fcb26705709a/src/Init/Prelude.lean#L2089-L2092","name":"Lean.Name.eraseMacroScopes","link":"/LeanColls/docs/semantic/563355226799390021.xml#","docLink":"/LeanColls/docs/Init/Prelude.html#Lean.Name.eraseMacroScopes","doc":""},{"sourceLink":"https://github.com/leanprover/lean4/blob/dca5da6b18d95ba75a16d5bcfb81fcb26705709a/src/Init/Prelude.lean#L2100-L2103","name":"Lean.Name.simpMacroScopes","link":"/LeanColls/docs/semantic/16196154667679741335.xml#","docLink":"/LeanColls/docs/Init/Prelude.html#Lean.Name.simpMacroScopes","doc":""},{"sourceLink":"https://github.com/leanprover/lean4/blob/dca5da6b18d95ba75a16d5bcfb81fcb26705709a/src/Init/Prelude.lean