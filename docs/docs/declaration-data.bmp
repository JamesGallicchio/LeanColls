n4/blob/dca5da6b18d95ba75a16d5bcfb81fcb26705709a/src/Init/Notation.lean#L375-L375","name":"Lean.Parser.Tactic.simpLemma","link":"/LeanColls/docs/semantic/11186679164186505719.xml#","docLink":"/LeanColls/docs/Init/Notation.html#Lean.Parser.Tactic.simpLemma","doc":""},{"sourceLink":"https://github.com/leanprover/lean4/blob/dca5da6b18d95ba75a16d5bcfb81fcb26705709a/src/Init/Notation.lean#L376-L376","name":"Lean.Parser.Tactic.simpErase","link":"/LeanColls/docs/semantic/15279754266353709603.xml#","docLink":"/LeanColls/docs/Init/Notation.html#Lean.Parser.Tactic.simpErase","doc":""},{"sourceLink":"https://github.com/leanprover/lean4/blob/dca5da6b18d95ba75a16d5bcfb81fcb26705709a/src/Init/Notation.lean#L377-L377","name":"Lean.Parser.Tactic.simpStar","link":"/LeanColls/docs/semantic/7604022633638082099.xml#","docLink":"/LeanColls/docs/Init/Notation.html#Lean.Parser.Tactic.simpStar","doc":""},{"sourceLink":"https://github.com/leanprover/lean4/blob/dca5da6b18d95ba75a16d5bcfb81fcb26705709a/src/Init/Notation.lean#L378-L378","name":"Lean.Parser.Tactic.simp","link":"/LeanColls/docs/semantic/5118178029511841149.xml#","docLink":"/LeanColls/docs/Init/Notation.html#Lean.Parser.Tactic.simp","doc":""},{"sourceLink":"https://github.com/leanprover/lean4/blob/dca5da6b18d95ba75a16d5bcfb81fcb26705709a/src/Init/Notation.lean#L379-L379","name":"Lean.Parser.Tactic.simpAll","link":"/LeanColls/docs/semantic/1777980890631261269.xml#","docLink":"/LeanColls/docs/Init/Notation.html#Lean.Parser.Tactic.simpAll","doc":""},{"sourceLink":"https://github.com/leanprover/lean4/blob/dca5da6b18d95ba75a16d5bcfb81fcb26705709a/src/Init/Notation.lean#L381-L384","name":"Lean.Parser.Tactic.delta","link":"/LeanColls/docs/semantic/8404102376702625875.xml#","docLink":"/LeanColls/docs/Init/Notation.html#Lean.Parser.Tactic.delta","doc":"Delta expand the given definition.\n  This is a low-level tactic, it will expose how recursive definitions have been compiled by Lean. "},{"sourceLink":"https://github.com/leanprover/lean4/blob/dca5da6b18d95ba75a16d5bcfb81fcb26705709a/src/Init/Notation.lean#L385-L389","name":"Lean.Parser.Tactic.unfold","link":"/LeanColls/docs/semantic/5921869961066811635.xml#","docLink":"/LeanColls/docs/Init/Notation.html#Lean.Parser.Tactic.unfold","doc":"Unfold definition. For non-recursive definitions, this tactic is identical to `delta`.\n  For recursive definitions, it hides the encoding tricks used by the Lean frontend to convince the\n  kernel that the definition terminates. "},{"sourceLink":"https://github.com/leanprover/lean4/blob/dca5da6b18d95ba75a16d5bcfb81fcb26705709a/src/Init/Notation.lean#L393-L393","name":"Lean.Parser.Tactic.tacticRefine_lift_","link":"/LeanColls/docs/semantic/6391212576157367071.xml#","docLink":"/LeanColls/docs/Init/Notation.html#Lean.Parser.Tactic.tacticRefine_lift_","doc":""},{"sourceLink":"https://github.com/leanprover/lean4/blob/dca5da6b18d95ba75a16d5bcfb81fcb26705709a/src/Init/Notation.lean#L395-L395","name":"Lean.Parser.Tactic.tacticHave_","link":"/LeanColls/docs/semantic/5943497921772062149.xml#","docLink":"/LeanColls/docs/Init/Notation.html#Lean.Parser.Tactic.tacticHave_","doc":""},{"sourceLink":"https://github.com/leanprover/lean4/blob/dca5da6b18d95ba75a16d5bcfb81fcb26705709a/src/Init/Notation.lean#L397-L397","name":"Lean.Parser.Tactic.«tacticHave__:=_»","link":"/LeanColls/docs/semantic/12352114813347208607.xml#","docLink":"/LeanColls/docs/Init/Notation.html#Lean.Parser.Tactic.«tacticHave__:=_»","doc":""},{"sourceLink":"https://github.com/leanprover/lean4/blob/dca5da6b18d95ba75a16d5bcfb81fcb26705709a/src/Init/Notation.lean#L398-L398","name":"Lean.Parser.Tactic.tacticSuffices_","link":"/LeanColls/docs/semantic/17216286269840812715.xml#","docLink":"/LeanColls/docs/Init/Notation.html#Lean.Parser.Tactic.tacticSuffices_","doc":""},{"sourceLink":"https://github.com/leanprover/lean4/blob/dca5da6b18d95ba75a16d5bcfb81fcb26705709a/src/Init/Notation.lean#L399-L399","name":"Lean.Parser.Tactic.tacticLet_","link":"/LeanColls/docs/semantic/11