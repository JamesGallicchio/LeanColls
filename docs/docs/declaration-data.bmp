22381.xml#","docLink":"./Init/Prelude.html#Monad","doc":""},{"sourceLink":"https://github.com/leanprover/lean4/blob/56cd6c1ff519d8be39f35875b5bf8719e6101c20/src/Init/Prelude.lean#L1339-L1340","name":"instInhabitedForAll_2","link":"./../semantic/17668998503976105273.xml#","docLink":"./Init/Prelude.html#instInhabitedForAll_2","doc":""},{"sourceLink":"https://github.com/leanprover/lean4/blob/56cd6c1ff519d8be39f35875b5bf8719e6101c20/src/Init/Prelude.lean#L1342-L1343","name":"instInhabited","link":"./../semantic/15162211161045186643.xml#","docLink":"./Init/Prelude.html#instInhabited","doc":""},{"sourceLink":"https://github.com/leanprover/lean4/blob/56cd6c1ff519d8be39f35875b5bf8719e6101c20/src/Init/Prelude.lean#L1346-L1354","name":"Array.sequenceMap","link":"./../semantic/15489152827786200339.xml#","docLink":"./Init/Prelude.html#Array.sequenceMap","doc":""},{"sourceLink":"https://github.com/leanprover/lean4/blob/56cd6c1ff519d8be39f35875b5bf8719e6101c20/src/Init/Prelude.lean#L1347-L1353","name":"Array.sequenceMap.loop","link":"./../semantic/15107992794036417129.xml#","docLink":"./Init/Prelude.html#Array.sequenceMap.loop","doc":""},{"sourceLink":"https://github.com/leanprover/lean4/blob/56cd6c1ff519d8be39f35875b5bf8719e6101c20/src/Init/Prelude.lean#L1360-L1361","name":"MonadLift","link":"./../semantic/9736395559119202625.xml#","docLink":"./Init/Prelude.html#MonadLift","doc":"A Function for lifting a computation from an inner Monad to an outer Monad.\n    Like [MonadTrans](https://hackage.haskell.org/package/transformers-0.5.5.0/docs/Control-Monad-Trans-Class.html),\n    but `n` does not have to be a monad transformer.\n    Alternatively, an implementation of [MonadLayer](https://hackage.haskell.org/package/layers-0.1/docs/Control-Monad-Layer.html#t:MonadLayer) without `layerInvmap` (so far). "},{"sourceLink":"https://github.com/leanprover/lean4/blob/56cd6c1ff519d8be39f35875b5bf8719e6101c20/src/Init/Prelude.lean#L1366-L1367","name":"MonadLiftT","link":"./../semantic/381548746434395927.xml#","docLink":"./Init/Prelude.html#MonadLiftT","doc":"The reflexive-transitive closure of `MonadLift`.\n    `monadLift` is used to transitively lift monadic computations such as `StateT.get` or `StateT.put s`.\n    Corresponds to [MonadLift](https://hackage.haskell.org/package/layers-0.1/docs/Control-Monad-Layer.html#t:MonadLift). "},{"sourceLink":"https://github.com/leanprover/lean4/blob/56cd6c1ff519d8be39f35875b5bf8719e6101c20/src/Init/Prelude.lean#L1371-L1371","name":"liftM","link":"./../semantic/12987064245804869883.xml#","docLink":"./Init/Prelude.html#liftM","doc":""},{"sourceLink":"https://github.com/leanprover/lean4/blob/56cd6c1ff519d8be39f35875b5bf8719e6101c20/src/Init/Prelude.lean#L1373-L1374","name":"instMonadLiftT","link":"./../semantic/14917147452098304751.xml#","docLink":"./Init/Prelude.html#instMonadLiftT","doc":""},{"sourceLink":"https://github.com/leanprover/lean4/blob/56cd6c1ff519d8be39f35875b5bf8719e6101c20/src/Init/Prelude.lean#L1376-L1377","name":"instMonadLiftT_1","link":"./../semantic/10798640905719535235.xml#","docLink":"./Init/Prelude.html#instMonadLiftT_1","doc":""},{"sourceLink":"https://github.com/leanprover/lean4/blob/56cd6c1ff519d8be39f35875b5bf8719e6101c20/src/Init/Prelude.lean#L1383-L1384","name":"MonadFunctor","link":"./../semantic/4687755728117868401.xml#","docLink":"./Init/Prelude.html#MonadFunctor","doc":"A functor in the category of monads. Can be used to lift monad-transforming functions.\n    Based on pipes' [MFunctor](https://hackage.haskell.org/package/pipes-2.4.0/docs/Control-MFunctor.html),\n    but not restricted to monad transformers.\n    Alternatively, an implementation of [MonadTransFunctor](http://duairc.netsoc.ie/layers-docs/Control-Monad-Layer.html#t:MonadTransFunctor). "},{"sourceLink":"https://github.com/leanprover/lean4/blob/56cd6c1ff519d8be39f35875b5bf8719e6101c20/src/Init/Prelude.lean#L1388-L1389","name":"MonadFunctorT","link":"./../semantic/18123828958563075195.xml#","docLink":"./Init/Prelude.html#MonadFunctorT","doc":"The reflexive-transitive closure of `MonadFunctor`.\n    `monadMap` is used to transitively lift Monad morphisms "},{"sourceLink":"https://github.com/leanprover/lean4/blob/56cd6c1ff519d8be39f35875b5bf8719e6101c20/src/Init/Prelude.lean#L1393-L1394","name":"instMonadFunctorT","link":"./../semantic/1036508886540296635.xml#","docLink":"./Init/Prelude.html#instMonadFunctorT","doc":""},{"sourceLink":"https://github.com/leanprover/lean4/blob/56cd6c1ff519d8be39f35875b5bf8719e6101c20/src/Init/Prelude.lean#L1396-L1397","name":"monadFunctorRefl","link":"./../semantic/4836349580557958813.xml#","docLink":"./Init/Prelude.html#monadFunctorRefl","doc":""},{"sourceLink":"https://github.com/leanprover/lean4/blob/56cd6c1ff519d8be39f35875b5bf8719e6101c20/src/Init/Prelude.lean#L1399-L1401","name":"Except","link":"./../semantic/15997936915438629699.xml#","docLink":"./Init/Prelude.html#Except","doc":""},{"sourceLink":"https://github.com/leanprover/lean4/blob/56cd6c1ff519d8be39f35875b5bf8719e6101c20/src/Init/Prelude.lean#L1405-L1406","name":"instInhabitedExcept","link":"./../semantic/10432223526081493177.xml#","docLink":"./Init/Prelude.html#instInhabitedExcept","doc":""},{"sourceLink":"https://github.com/leanprover/lean4/blob/56cd6c1ff519d8be39f35875b5bf8719e6101c20/src/Init/Prelude.lean#L1409-L1411","name":"MonadExceptOf","link":"./../semantic/14901874458683113123.xml#","docLink":"./Init/Prelude.html#MonadExceptOf","doc":"An implementation of [MonadError](https://hackage.haskell.org/package/mtl-2.2.2/docs/Control-Monad-Except.html#t:MonadError) "},{"sourceLink":"https://github.com/leanprover/lean4/blob/56cd6c1ff519d8be39f35875b5bf8719e6101c20/src/Init/Prelude.lean#L1413-L1414","name":"throwThe","link":"./../semantic/9586951218528766351.xml#","docLink":"./Init/Prelude.html#throwThe","doc":""},{"sourceLink":"https://github.com/leanprover/lean4/blob/56cd6c1ff519d8be39f35875b5bf8719e6101c20/src/Init/Prelude.lean#L1416-L1417","name":"tryCatchThe","link":"./../semantic/12303949411325939583.xml#","docLink":"./Init/Prelude.html#tryCatchThe","doc":""},{"sourceLink":"https://github.com/leanprover/lean4/blob/56cd6c1ff519d8be39f35875b5bf8719e6101c20/src/Init/Prelude.lean#L1420-L1422","name":"MonadExcept","link":"./../semantic/4432101628009795677.xml#","docLink":"./Init/Prelude.html#MonadExcept","doc":"Similar to `MonadExceptOf`, but `ε` is an outParam for convenience "},{"sourceLink":"https://github.com/leanprover/lean4/blob/56cd6c1ff519d8be39f35875b5bf8719e6101c20/src/Init/Prelude.lean#L1426-L1428","name":"instMonadExcept","link":"./../semantic/5067230567468901169.xml#","docLink":"./Init/Prelude.html#instMonadExcept","doc":""},{"sourceLink":"https://github.com/leanprover/lean4/blob/56cd6c1ff519d8be39f35875b5bf8719e6101c20/src/Init/Prelude.lean#L1433-L1434","name":"MonadExcept.orElse","link":"./../semantic/10022450353203115407.xml#","docLink":"./Init/Prelude.html#MonadExcept.orElse","doc":""},{"sourceLink":"https://github.com/leanprover/lean4/blob/56cd6c1ff519d8be39f35875b5bf8719e6101c20/src/Init/Prelude.lean#L1436-L1437","name":"MonadExcept.instOrElse","link":"./../semantic/11060003731656798665.xml#","docLink":"./Init/Prelude.html#MonadExcept.instOrElse","doc":""},{"sourceLink":"https://github.com/leanprover/lean4/blob/56cd6c1ff519d8be39f35875b5bf8719e6101c20/src/Init/Prelude.lean#L1442-L1443","name":"ReaderT","link":"./../semantic/10394969777436541257.xml#","docLink":"./Init/Prelude.html#ReaderT","doc":"An implementation of [ReaderT](https://hackage.haskell.org/package/transformers-0.5.5.0/docs/Control-Monad-Trans-Reader.html#t:ReaderT) "},{"sourceLink":"https://github.com/leanprover/lean4/blob/56cd6c1ff519d8be39f35875b5bf8719e6101c20/src/Init/Prelude.lean#L1445-L1446","name":"instInhabitedReaderT","link":"./../semantic/18177704223846160607.xml#","docLink":"./Init/Prelude.html#instInhabitedReaderT","doc":""},{"sourceLink":"https://github.com/leanprover/lean4/blob/56cd6c1ff519d8be39f35875b5bf8719e6101c20/src/Init/Prelude.lean#L1448-L1449"