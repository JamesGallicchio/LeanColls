6699361552676018119.xml#","docLink":"/LeanColls/docs/Init/Prelude.html#ReaderT.pure","doc":""},{"sourceLink":"https://github.com/leanprover/lean4/blob/dca5da6b18d95ba75a16d5bcfb81fcb26705709a/src/Init/Prelude.lean#L1444-L1445","name":"ReaderT.bind","link":"/LeanColls/docs/semantic/8383871963726216541.xml#","docLink":"/LeanColls/docs/Init/Prelude.html#ReaderT.bind","doc":""},{"sourceLink":"https://github.com/leanprover/lean4/blob/dca5da6b18d95ba75a16d5bcfb81fcb26705709a/src/Init/Prelude.lean#L1447-L1448","name":"ReaderT.map","link":"/LeanColls/docs/semantic/14560868847301446063.xml#","docLink":"/LeanColls/docs/Init/Prelude.html#ReaderT.map","doc":""},{"sourceLink":"https://github.com/leanprover/lean4/blob/dca5da6b18d95ba75a16d5bcfb81fcb26705709a/src/Init/Prelude.lean#L1450-L1453","name":"ReaderT.instMonadReaderT","link":"/LeanColls/docs/semantic/4900943689281013789.xml#","docLink":"/LeanColls/docs/Init/Prelude.html#ReaderT.instMonadReaderT","doc":""},{"sourceLink":"https://github.com/leanprover/lean4/blob/dca5da6b18d95ba75a16d5bcfb81fcb26705709a/src/Init/Prelude.lean#L1455-L1456","name":"ReaderT.instMonadFunctorReaderT","link":"/LeanColls/docs/semantic/2392877204396585085.xml#","docLink":"/LeanColls/docs/Init/Prelude.html#ReaderT.instMonadFunctorReaderT","doc":""},{"sourceLink":"https://github.com/leanprover/lean4/blob/dca5da6b18d95ba75a16d5bcfb81fcb26705709a/src/Init/Prelude.lean#L1458-L1459","name":"ReaderT.adapt","link":"/LeanColls/docs/semantic/12384613039398123723.xml#","docLink":"/LeanColls/docs/Init/Prelude.html#ReaderT.adapt","doc":""},{"sourceLink":"https://github.com/leanprover/lean4/blob/dca5da6b18d95ba75a16d5bcfb81fcb26705709a/src/Init/Prelude.lean#L1474-L1475","name":"MonadReaderOf","link":"/LeanColls/docs/semantic/10533766956922484081.xml#","docLink":"/LeanColls/docs/Init/Prelude.html#MonadReaderOf","doc":"An implementation of [MonadReader](https://hackage.haskell.org/package/mtl-2.2.2/docs/Control-Monad-Reader-Class.html#t:MonadReader).\n    It does not contain `local` because this Function cannot be lifted using `monadLift`.\n    Instead, the `MonadReaderAdapter` class provides the more general `adaptReader` Function.\n\n    Note: This class can be seen as a simplification of the more \"principled\" definition\n    ```\n    class MonadReader (ρ : outParam (Type u)) (n : Type u → Type u) where\n      lift {α : Type u} : ({m : Type u → Type u} → [Monad m] → ReaderT ρ m α) → n α\n    ```\n    "},{"sourceLink":"https://github.com/leanprover/lean4/blob/dca5da6b18d95ba75a16d5bcfb81fcb26705709a/src/Init/Prelude.lean#L1477-L1478","name":"readThe","link":"/LeanColls/docs/semantic/10593506447829829991.xml#","docLink":"/LeanColls/docs/Init/Prelude.html#readThe","doc":""},{"sourceLink":"https://github.com/leanprover/lean4/blob/dca5da6b18d95ba75a16d5bcfb81fcb26705709a/src/Init/Prelude.lean#L1481-L1482","name":"MonadReader","link":"/LeanColls/docs/semantic/12104392566556993199.xml#","docLink":"/LeanColls/docs/Init/Prelude.html#MonadReader","doc":"Similar to `MonadReaderOf`, but `ρ` is an outParam for convenience "},{"sourceLink":"https://github.com/leanprover/lean4/blob/dca5da6b18d95ba75a16d5bcfb81fcb26705709a/src/Init/Prelude.lean#L1486-L1487","name":"instMonadReader","link":"/LeanColls/docs/semantic/17110539146863322339.xml#","docLink":"/LeanColls/docs/Init/Prelude.html#instMonadReader","doc":""},{"sourceLink":"https://github.com/leanprover/lean4/blob/dca5da6b18d95ba75a16d5bcfb81fcb26705709a/src/Init/Prelude.lean#L1489-L1490","name":"instMonadReaderOf","link":"/LeanColls/docs/semantic/11286806910902602249.xml#","docLink":"/LeanColls/docs/Init/Prelude.html#instMonadReaderOf","doc":""},{"sourceLink":"https://github.com/leanprover/lean4/blob/dca5da6b18d95ba75a16d5bcfb81fcb26705709a/src/Init/Prelude.lean#L1492-L1493","name":"instMonadReaderOfReaderT","link":"/LeanColls/docs/semantic/9799199573612922181.xml#","docLink":"/LeanColls/docs/Init/Prelude.html#instMonadReaderOfReaderT","doc":""},{"sourceLink":"https://github.com/leanpr