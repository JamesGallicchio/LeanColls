9788185.xml#","docLink":"/LeanColls/docs/Init/System/IO.html#IO.initializing","doc":""},{"sourceLink":"https://github.com/leanprover/lean4/blob/dca5da6b18d95ba75a16d5bcfb81fcb26705709a/src/Init/System/IO.lean#L112-L113","name":"BaseIO.asTask","link":"/LeanColls/docs/semantic/7594025200829499833.xml#","docLink":"/LeanColls/docs/Init/System/IO.html#BaseIO.asTask","doc":"Run `act` in a separate `Task`.\n  This is similar to Haskell's [`unsafeInterleaveIO`](http://hackage.haskell.org/package/base-4.14.0.0/docs/System-IO-Unsafe.html#v:unsafeInterleaveIO),\n  except that the `Task` is started eagerly as usual. Thus pure accesses to the `Task` do not influence the impure `act`\n  computation.\n  Unlike with pure tasks created by `Task.spawn`, tasks created by this function will be run even if the last reference\n  to the task is dropped. The `act` should manually check for cancellation via `IO.checkCanceled` if it wants to react\n  to that. "},{"sourceLink":"https://github.com/leanprover/lean4/blob/dca5da6b18d95ba75a16d5bcfb81fcb26705709a/src/Init/System/IO.lean#L117-L118","name":"BaseIO.mapTask","link":"/LeanColls/docs/semantic/17257034048184449093.xml#","docLink":"/LeanColls/docs/Init/System/IO.html#BaseIO.mapTask","doc":"See `BaseIO.asTask`. "},{"sourceLink":"https://github.com/leanprover/lean4/blob/dca5da6b18d95ba75a16d5bcfb81fcb26705709a/src/Init/System/IO.lean#L122-L123","name":"BaseIO.bindTask","link":"/LeanColls/docs/semantic/11982490333761907337.xml#","docLink":"/LeanColls/docs/Init/System/IO.html#BaseIO.bindTask","doc":"See `BaseIO.asTask`. "},{"sourceLink":"https://github.com/leanprover/lean4/blob/dca5da6b18d95ba75a16d5bcfb81fcb26705709a/src/Init/System/IO.lean#L125-L131","name":"BaseIO.mapTasks","link":"/LeanColls/docs/semantic/9624263982319553109.xml#","docLink":"/LeanColls/docs/Init/System/IO.html#BaseIO.mapTasks","doc":""},{"sourceLink":"https://github.com/leanprover/lean4/blob/dca5da6b18d95ba75a16d5bcfb81fcb26705709a/src/Init/System/IO.lean#L128-L131","name":"BaseIO.mapTasks.go","link":"/LeanColls/docs/semantic/15841804138086935943.xml#","docLink":"/LeanColls/docs/Init/System/IO.html#BaseIO.mapTasks.go","doc":""},{"sourceLink":"https://github.com/leanprover/lean4/blob/dca5da6b18d95ba75a16d5bcfb81fcb26705709a/src/Init/System/IO.lean#L138-L139","name":"EIO.asTask","link":"/LeanColls/docs/semantic/14819062376051101579.xml#","docLink":"/LeanColls/docs/Init/System/IO.html#EIO.asTask","doc":"`EIO` specialization of `BaseIO.asTask`. "},{"sourceLink":"https://github.com/leanprover/lean4/blob/dca5da6b18d95ba75a16d5bcfb81fcb26705709a/src/Init/System/IO.lean#L142-L143","name":"EIO.mapTask","link":"/LeanColls/docs/semantic/4394760030920261143.xml#","docLink":"/LeanColls/docs/Init/System/IO.html#EIO.mapTask","doc":"`EIO` specialization of `BaseIO.mapTask`. "},{"sourceLink":"https://github.com/leanprover/lean4/blob/dca5da6b18d95ba75a16d5bcfb81fcb26705709a/src/Init/System/IO.lean#L146-L147","name":"EIO.bindTask","link":"/LeanColls/docs/semantic/8345828982897340507.xml#","docLink":"/LeanColls/docs/Init/System/IO.html#EIO.bindTask","doc":"`EIO` specialization of `BaseIO.bindTask`. "},{"sourceLink":"https://github.com/leanprover/lean4/blob/dca5da6b18d95ba75a16d5bcfb81fcb26705709a/src/Init/System/IO.lean#L150-L151","name":"EIO.mapTasks","link":"/LeanColls/docs/semantic/5676535629122474023.xml#","docLink":"/LeanColls/docs/Init/System/IO.html#EIO.mapTasks","doc":"`EIO` specialization of `BaseIO.mapTasks`. "},{"sourceLink":"https://github.com/leanprover/lean4/blob/dca5da6b18d95ba75a16d5bcfb81fcb26705709a/src/Init/System/IO.lean#L157-L160","name":"IO.ofExcept","link":"/LeanColls/docs/semantic/11496952375791312535.xml#","docLink":"/LeanColls/docs/Init/System/IO.html#IO.ofExcept","doc":""},{"sourceLink":"https://github.com/leanprover/lean4/blob/dca5da6b18d95ba75a16d5bcfb81fcb26705709a/src/Init/System/IO.lean#L162-L163","name":"IO.lazyPure","link":"/LeanColls/docs/semantic/12651153770804327471.xml#","docLink":"/LeanColls/docs/Init/System/IO.html#IO.lazyPure","doc":""},{"sourceLink":"https://github.com/leanprover/lean4/blob/dca5da6b18d95ba75a16d5bcfb81fcb26705709a/src/Init/System/IO.lean#L166-L166","name":"IO.monoMsNow","link":"/LeanColls/docs/semantic/870973468643168101.xml#","docLink":"/LeanColls/docs/Init/System/IO.html#IO.monoMsNow","doc":"Monotonically increasing time since an unspecified past point in milliseconds. No relation to wall clock time. "},{"sourceLink":"https://github.com/leanprover/lean4/blob/dca5da6b18d95ba75a16d5bcfb81fcb26705709a/src/Init/System/IO.lean#L170-L170","name":"IO.getRandomBytes","link":"/LeanColls/docs/semantic/14646183813668122873.xml#","docLink":"/LeanColls/docs/Init/System/IO.html#IO.getRandomBytes","doc":"Read bytes from a system entropy source. Not guaranteed to be cryptographically secure.\nIf `nBytes = 0`, return immediately with an empty buffer. "},{"sourceLink":"https://github.com/leanprover/lean4/blob/dca5da6b18d95ba75a16d5bcfb81fcb26705709a/src/Init/System/IO.lean#L172-L174","name":"IO.sleep","link":"/LeanColls/docs/semantic/3850668590487580061.xml#","docLink":"/LeanColls/docs/Init/System/IO.html#IO.sleep","doc":""},{"sourceLink":"https://github.com/leanprover/lean4/blob/dca5da6b18d95ba75a16d5bcfb81fcb26705709a/src/Init/System/IO.lean#L177-L178","name":"IO.asTask","link":"/LeanColls/docs/semantic/5612627944362664081.xml#","docLink":"/LeanColls/docs/Init/System/IO.html#IO.asTask","doc":"`IO` specialization of `EIO.asTask`. "},{"sourceLink":"https://github.com/leanprover/lean4/blob/dca5da6b18d95ba75a16d5bcfb81fcb26705709a/src/Init/System/IO.lean#L181-L182","name":"IO.mapTask","link":"/LeanColls/docs/semantic/4575841284117450525.xml#","docLink":"/LeanColls/docs/Init/System/IO.html#IO.mapTask","doc":"`IO` specialization of `EIO.mapTask`. "},{"sourceLink":"https://github.com/leanprover/lean4/blob/dca5da6b18d95ba75a16d5bcfb81fcb26705709a/src/Init/System/IO.lean#L185-L186","name":"IO.bindTask","link":"/LeanColls/docs/semantic/5130881568265109857.xml#","docLink":"/LeanColls/docs/Init/System/IO.html#IO.bindTask","doc":"`IO` specialization of `EIO.bindTask`. "},{"sourceLink":"https://github.com/leanprover/lean4/blob/dca5da6b18d95ba75a16d5bcfb81fcb26705709a/src/Init/System/IO.lean#L189-L190","name":"IO.mapTasks","link":"/LeanColls/docs/semantic/8034703989779636525.xml#","docLink":"/LeanColls/docs/Init/System/IO.html#IO.mapTasks","doc":"`IO` specialization of `EIO.mapTasks`. "},{"sourceLink":"https://github.com/leanprover/lean4/blob/dca5da6b18d95ba75a16d5bcfb81fcb26705709a/src/Init/System/IO.lean#L193-L193","name":"IO.checkCanceled","link":"/LeanColls/docs/semantic/11714283910550026471.xml#","docLink":"/LeanColls/docs/Init/System/IO.html#IO.checkCanceled","doc":"Check if the task's cancellation flag has been set by calling `IO.cancel` or dropping the last reference to the task. "},{"sourceLink":"https://github.com/leanprover/lean4/blob/dca5da6b18d95ba75a16d5bcfb81fcb26705709a/src/Init/System/IO.lean#L196-L196","name":"IO.cancel","link":"/LeanColls/docs/semantic/1879614332610681999.xml#","docLink":"/LeanColls/docs/Init/System/IO.html#IO.cancel","doc":"Request cooperative cancellation of the task. The task must explicitly call `IO.checkCanceled` to react to the cancellation. "},{"sourceLink":"https://github.com/leanprover/lean4/blob/dca5da6b18d95ba75a16d5bcfb81fcb26705709a/src/Init/System/IO.lean#L199-L199","name":"IO.hasFinished","link":"/LeanColls/docs/semantic/10312564099085458409.xml#","docLink":"/LeanColls/docs/Init/System/IO.html#IO.hasFinished","doc":"Check if the task has finished execution, at which point calling `Task.get` will return immediately. "},{"sourceLink":"https://github.com/leanprover/lean4/blob/dca5da6b18d95ba75a16d5bcfb81fcb26705709a/src/Init/System/IO.lean#L202-L203","name":"IO.wait","link":"/LeanColls/docs/semantic/7322173212267685123.xml#","docLink":"/LeanColls/docs/Init/System/IO.html#IO.wait","doc":"Wait for the task to finish, then return its result. "},{"sourceLink":"https://github.com/leanprover/lean4/blob/dca5da6b18d95ba75a16d5bcfb81fcb26705709a/src/Init/System/IO.lean#L206-L206","name":"IO.waitAny","link":"/LeanColls/docs/semantic/1201965408311303597.xml#","docLink":"/LeanColls/docs/Init/System/IO.html#IO.waitAny","doc":"Wait until any of the tasks in the given list has finished, then return its result. "},{"sourceLink":"https://github.com/leanprover/lean4/blob/dca5da6b18d95ba75a16d5bcfb81fcb26705709a/src/Init/System/IO.lean#L209-L209","name":"IO.getNumHeartbeats","link":"/LeanColls/docs/semantic/487045709297012313.xml#","docLink":"/LeanColls/docs/Init/System/IO.html#IO.getNumHeartbeats","doc":"Helper method for implementing \"deterministic\" timeouts. It is the number of \"small\" memory allocations performed by the current execution thread. "},{"sourceLink":"https://github.com/leanprover/lean4/blob/dca5da6b18d95ba75a16d5bcfb81fcb26705709a/src/Init/System/IO.lean#L211-L212","name":"IO.FS.Mode","link":"/LeanColls/docs/semantic/13574445258479993127.xml#","docLink":"/LeanColls/docs/Init/System/IO.html#IO.FS.Mode","doc":""},{"sourceLink":"https://github.com/leanprover/lean4/blob/dca5da6b18d95ba75a16d5bcfb81fcb26705709a/src/Init/System/IO.lean#L214-L214","name":"IO.FS.Handle","link":"/LeanColls/docs/semantic/9223687047290027699.xml#","docLink":"/LeanColls/docs/Init/System/IO.html#IO.FS.Handle","doc":""},{"sourceLink":"https://github.com/leanprover/lean4/blob/dca5da6b18d95ba75a16d5bcfb81fcb26705709a/src/Init/System/IO.lean#L219-L226","name":"IO.FS.Stream","link":"/LeanColls/docs/semantic/2026126783982812667.xml#","docLink":"/LeanColls/docs/Init/System/IO.html#IO.FS.Stream","doc":"A pure-Lean abstraction of POSIX streams. We use `Stream`s for the standard streams stdin/stdout/stderr so we can\n  capture output of `#eval` commands into memory. "},{"sourceLink":"https://github.com/leanprover/lean4/blob/dca5da6b18d95ba75a16d5bcfb81fcb26705709a/src/Init/System/IO.lean#L226-L226","name":"IO.FS.instInhabitedStream","link":"/LeanColls/docs/semantic/10906983851608941637.xml#","do