m/leanprover/lean4/blob/56cd6c1ff519d8be39f35875b5bf8719e6101c20/src/Init/Core.lean#L1019-L1020","name":"Function.Equiv.refl","link":"./../semantic/17898452159493431605.xml#","docLink":"./Init/Core.html#Function.Equiv.refl","doc":""},{"sourceLink":"https://github.com/leanprover/lean4/blob/56cd6c1ff519d8be39f35875b5bf8719e6101c20/src/Init/Core.lean#L1022-L1023","name":"Function.Equiv.symm","link":"./../semantic/6996031123611826793.xml#","docLink":"./Init/Core.html#Function.Equiv.symm","doc":""},{"sourceLink":"https://github.com/leanprover/lean4/blob/56cd6c1ff519d8be39f35875b5bf8719e6101c20/src/Init/Core.lean#L1025-L1026","name":"Function.Equiv.trans","link":"./../semantic/12107234229129392317.xml#","docLink":"./Init/Core.html#Function.Equiv.trans","doc":""},{"sourceLink":"https://github.com/leanprover/lean4/blob/56cd6c1ff519d8be39f35875b5bf8719e6101c20/src/Init/Core.lean#L1028-L1032","name":"Function.Equiv.isEquivalence","link":"./../semantic/13092246301978683317.xml#","docLink":"./Init/Core.html#Function.Equiv.isEquivalence","doc":""},{"sourceLink":"https://github.com/leanprover/lean4/blob/56cd6c1ff519d8be39f35875b5bf8719e6101c20/src/Init/Core.lean#L1049-L1053","name":"funext","link":"./../semantic/12591759012935502197.xml#","docLink":"./Init/Core.html#funext","doc":""},{"sourceLink":"https://github.com/leanprover/lean4/blob/56cd6c1ff519d8be39f35875b5bf8719e6101c20/src/Init/Core.lean#L1057-L1059","name":"instSubsingletonForAll","link":"./../semantic/6189963127257624533.xml#","docLink":"./Init/Core.html#instSubsingletonForAll","doc":""},{"sourceLink":"https://github.com/leanprover/lean4/blob/56cd6c1ff519d8be39f35875b5bf8719e6101c20/src/Init/Core.lean#L1063-L1063","name":"Squash","link":"./../semantic/13838093935347341729.xml#","docLink":"./Init/Core.html#Squash","doc":""},{"sourceLink":"https://github.com/leanprover/lean4/blob/56cd6c1ff519d8be39f35875b5bf8719e6101c20/src/Init/Core.lean#L1065-L1065","name":"Squash.mk","link":"./../semantic/10002115130439814465.xml#","docLink":"./Init/Core.html#Squash.mk","doc":""},{"sourceLink":"https://github.com/leanprover/lean4/blob/56cd6c1ff519d8be39f35875b5bf8719e6101c20/src/Init/Core.lean#L1067-L1068","name":"Squash.ind","link":"./../semantic/10962331087870900833.xml#","docLink":"./Init/Core.html#Squash.ind","doc":""},{"sourceLink":"https://github.com/leanprover/lean4/blob/56cd6c1ff519d8be39f35875b5bf8719e6101c20/src/Init/Core.lean#L1070-L1071","name":"Squash.lift","link":"./../semantic/11044777989481719313.xml#","docLink":"./Init/Core.html#Squash.lift","doc":""},{"sourceLink":"https://github.com/leanprover/lean4/blob/56cd6c1ff519d8be39f35875b5bf8719e6101c20/src/Init/Core.lean#L1073-L1078","name":"instSubsingletonSquash","link":"./../semantic/17217806166988294103.xml#","docLink":"./Init/Core.html#instSubsingletonSquash","doc":""},{"sourceLink":"https://github.com/leanprover/lean4/blob/56cd6c1ff519d8be39f35875b5bf8719e6101c20/src/Init/Core.lean#L1082-L1083","name":"Antisymm","link":"./../semantic/10986142430358551047.xml#","docLink":"./Init/Core.html#Antisymm","doc":""},{"sourceLink":"https://github.com/leanprover/lean4/blob/56cd6c1ff519d8be39f35875b5bf8719e6101c20/src/Init/Core.lean#L1107-L1107","name":"Lean.reduceBool","link":"./../semantic/682439376968744767.xml#","docLink":"./Init/Core.html#Lean.reduceBool","doc":"When the kernel tries to reduce a term `Lean.reduceBool c`, it will invoke the Lean interpreter to evaluate `c`.\n  The kernel will not use the interpreter if `c` is not a constant.\n  This feature is useful for performing proofs by reflection.\n\n  Remark: the Lean frontend allows terms of the from `Lean.reduceBool t` where `t` is a term not containing\n  free variables. The frontend automatically declares a fresh auxiliary constant `c` and replaces the term with\n  `Lean.reduceBool c`. The main motivation is that the code for `t` will be pre-compiled.\n\n  Warning: by using this feature, the Lean compiler and interpreter become part of your trusted code base.\n  This is extra 30k lines of code. More importantly, you will probably not be able to check your developement using\n  external type checkers (e.g., Trepplein) that do not implement this feature.\n  Keep in mind that if you are using Lean as programming language, you are already trusting the Lean compiler and interpreter.\n  So, you are mainly losing the capability of type checking your developement using external checkers.\n\n  Recall that the compiler trusts the correctness of all `[implementedBy ...]` and `[extern ...]` annotations.\n  If an extern function is executed, then the trusted code base will also include the implementation of the associated\n  foreign function.\n"},{"sourceLink":"https://github.com/leanprover/lean4/blob/56cd6c1ff519d8be39f35875b5bf8719e6101c20/src/Init/Core.lean#L1115-L1115","name":"Lean.reduceNat","link":"./../semantic/6080278544671899441.xml#","docLink":"./Init/Core.html#Lean.reduceNat","doc":"Similar to `Lean.reduceBool` for closed `Nat` terms.\n\n  Remark: we do not have plans for supporting a generic `reduceValue {α} (a : α) : α := a`.\n  The main issue is that it is non-trivial to convert an arbitrary runtime object back into a Lean expression.\n  We believe `Lean.reduceBool` enables most interesting applications (e.g., proof by reflection). "},{"sourceLink":"https://github.com/leanprover/lean4/blob/56cd6c1ff519d8be39f35875b5bf8719e6101c20/src/Init/Core.lean#L1117-L1117","name":"Lean.ofReduceBool","link":"./../semantic/16592443193419380569.xml#","docLink":"./Init/Core.html#Lean.ofReduceBool","doc":""},{"sourceLink":"https://github.com/leanprover/lean4/blob/56cd6c1ff519d8be39f35875b5bf8719e6101c20/src/Init/Core.lean#L1118-L1118","name":"Lean.ofReduceNat","link":"./../semantic/16644529548177384939.xml#","docLink":"./Init/Core.html#Lean.ofReduceNat","doc":""},{"sourceLink":"https://github.com/leanprover/lean4/blob/56cd6c1ff519d8be39f35875b5bf8719e6101c20/src/Init/Core.lean#L1120-L1121","name":"Lean.IsAssociative","link":"./../semantic/398902933202033109.xml#","docLink":"./Init/Core.html#Lean.IsAssociative","doc":""},{"sourceLink":"https://github.com/leanprover/lean4/blob/56cd6c1ff519d8be39f35875b5bf8719e6101c20/src/Init/Core.lean#L1123-L1124","name":"Lean.IsCommutative","link":"./../semantic/664836155567465371.xml#","docLink":"./Init/Core.html#Lean.IsCommutative","doc":""},{"sourceLink":"https://github.com/leanprover/lean4/blob/56cd6c1ff519d8be39f35875b5bf8719e6101c20/src/Init/Core.lean#L1126-L1127","name":"Lean.IsIdempotent","link":"./../semantic/4684367959198651439.xml#","docLink":"./Init/Core.html#Lean.IsIdempotent","doc":""},{"sourceLink":"https://github.com/leanprover/lean4/blob/56cd6c1ff519d8be39f35875b5bf8719e6101c20/src/Init/Core.lean#L1129-L1131","name":"Lean.IsNeutral","link":"./../semantic/3033886159435338195.xml#","docLink":"./Init/Core.html#Lean.IsNeutral","doc":""},{"sourceLink":"https://github.com/leanprover/lean4/blob/56cd6c1ff519d8be39f35875b5bf8719e6101c20/src/Init/Control/Option.lean#L13-L13","name":"instToBoolOption","link":"./../semantic/3883707368092852493.xml#","docLink":"./Init/Control/Option.html#instToBoolOption","doc":""},{"sourceLink":"https://github.com/leanprover/lean4/blob/56cd6c1ff519d8be39f35875b5bf8719e6101c20/src/Init/Control/Option.lean#L15-L16","name":"OptionT","link":"./../semantic/17531809942691213203.xml#","docLink":"./Init/Control/Option.html#OptionT","doc":""},{"sourceLink":"https://github.com/leanprover/lean4/blob/56cd6c1ff519d8be39f35875b5bf8719e6101c20/src/Init/Control/Option.lean#L18-L19","name":"OptionT.run","link":"./../semantic/4700653848104054253.xml#","docLink":"./Init/Control/Option.html#OptionT.run","doc":""},{"sourceLink":"https://github.com/leanprover/lean4/blob/56cd6c1ff519d8be39f35875b5bf8719e6101c20/src/Init/Control/Option.lean#L24-L25","name":"OptionT.mk","link":"./../semantic/17115255036035287915.xml#","docLink":"./Init/Control/Option.html#OptionT.mk","doc":""},{"sourceLink":"https://github.com/leanprover/lean4/blob/56cd6c1ff519d8be39f35875b5bf8719e