ff519d8be39f35875b5bf8719e6101c20/src/Init/Prelude.lean#L2023-L2025","name":"Lean.instMonadRef","link":"./../semantic/5021370926824609033.xml#","docLink":"./Init/Prelude.html#Lean.instMonadRef","doc":""},{"sourceLink":"https://github.com/leanprover/lean4/blob/56cd6c1ff519d8be39f35875b5bf8719e6101c20/src/Init/Prelude.lean#L2027-L2030","name":"Lean.replaceRef","link":"./../semantic/7398094282883011891.xml#","docLink":"./Init/Prelude.html#Lean.replaceRef","doc":""},{"sourceLink":"https://github.com/leanprover/lean4/blob/56cd6c1ff519d8be39f35875b5bf8719e6101c20/src/Init/Prelude.lean#L2032-L2035","name":"Lean.withRef","link":"./../semantic/15383426096281266899.xml#","docLink":"./Init/Prelude.html#Lean.withRef","doc":""},{"sourceLink":"https://github.com/leanprover/lean4/blob/56cd6c1ff519d8be39f35875b5bf8719e6101c20/src/Init/Prelude.lean#L2045-L2060","name":"Lean.MonadQuotation","link":"./../semantic/17431967815716861113.xml#","docLink":"./Init/Prelude.html#Lean.MonadQuotation","doc":"A monad that supports syntax quotations. Syntax quotations (in term\n    position) are monadic values that when executed retrieve the current \"macro\n    scope\" from the monad and apply it to every identifier they introduce\n    (independent of whether this identifier turns out to be a reference to an\n    existing declaration, or an actually fresh binding during further\n    elaboration). We also apply the position of the result of `getRef` to each\n    introduced symbol, which results in better error positions than not applying\n    any position. "},{"sourceLink":"https://github.com/leanprover/lean4/blob/56cd6c1ff519d8be39f35875b5bf8719e6101c20/src/Init/Prelude.lean#L2064-L2065","name":"Lean.MonadRef.mkInfoFromRefPos","link":"./../semantic/10545846489816252281.xml#","docLink":"./Init/Prelude.html#Lean.MonadRef.mkInfoFromRefPos","doc":""},{"sourceLink":"https://github.com/leanprover/lean4/blob/56cd6c1ff519d8be39f35875b5bf8719e6101c20/src/Init/Prelude.lean#L2067-L2070","name":"Lean.instMonadQuotation","link":"./../semantic/3435522609680447271.xml#","docLink":"./Init/Prelude.html#Lean.instMonadQuotation","doc":""},{"sourceLink":"https://github.com/leanprover/lean4/blob/56cd6c1ff519d8be39f35875b5bf8719e6101c20/src/Init/Prelude.lean#L2093-L2096","name":"Lean.Name.hasMacroScopes","link":"./../semantic/5734167616164134465.xml#","docLink":"./Init/Prelude.html#Lean.Name.hasMacroScopes","doc":""},{"sourceLink":"https://github.com/leanprover/lean4/blob/56cd6c1ff519d8be39f35875b5bf8719e6101c20/src/Init/Prelude.lean#L2106-L2109","name":"Lean.Name.eraseMacroScopes","link":"./../semantic/563355226799390021.xml#","docLink":"./Init/Prelude.html#Lean.Name.eraseMacroScopes","doc":""},{"sourceLink":"https://github.com/leanprover/lean4/blob/56cd6c1ff519d8be39f35875b5bf8719e6101c20/src/Init/Prelude.lean#L2117-L2120","name":"Lean.Name.simpMacroScopes","link":"./../semantic/16196154667679741335.xml#","docLink":"./Init/Prelude.html#Lean.Name.simpMacroScopes","doc":""},{"sourceLink":"https://github.com/leanprover/lean4/blob/56cd6c1ff519d8be39f35875b5bf8719e6101c20/src/Init/Prelude.lean#L2122-L2126","name":"Lean.MacroScopesView","link":"./../semantic/15067541647709748881.xml#","docLink":"./Init/Prelude.html#Lean.MacroScopesView","doc":""},{"sourceLink":"https://github.com/leanprover/lean4/blob/56cd6c1ff519d8be39f35875b5bf8719e6101c20/src/Init/Prelude.lean#L2128-L2129","name":"Lean.instInhabitedMacroScopesView","link":"./../semantic/3151714501039196337.xml#","docLink":"./Init/Prelude.html#Lean.instInhabitedMacroScopesView","doc":""},{"sourceLink":"https://github.com/leanprover/lean4/blob/56cd6c1ff519d8be39f35875b5bf8719e6101c20/src/Init/Prelude.lean#L2131-L2136","name":"Lean.MacroScopesView.review","link":"./../semantic/12872437773143571655.xml#","docLink":"./Init/Prelude.html#Lean.MacroScopesView.review","doc":""},{"sourceLink":"https://github.com/leanprover/lean4/blob/56cd6c1ff519d8be39f35875b5bf8719e6101c20/src/Init/Prelude.lean#L2169-L2172","name":"Lean.extractMacroScopes","link":"./../semantic/320142478366652045.xml#","docLink":"./Init/Prelude.html#Lean.extractMacroScopes","doc":"Revert all `addMacroScope` calls. `v = extractMacroScopes n → n = v.review`.\n  This operation is useful for analyzing/transforming the original identifiers, then adding back\n  the scopes (via `MacroScopesView.review`). "},{"sourceLink":"https://github.com/leanprover/lean4/blob/56cd6c1ff519d8be39f35875b5bf8719e6101c20/src/Init/Prelude.lean#L2174-L2187","name":"Lean.addMacroScope","link":"./../semantic/10689460090091679023.xml#","docLink":"./Init/Prelude.html#Lean.addMacroScope","doc":""},{"sourceLink":"https://github.com/leanprover/lean4/blob/56cd6c1ff519d8be39f35875b5bf8719e6101c20/src/Init/Prelude.lean#L2189-L2192","name":"Lean.MonadQuotation.addMacroScope","link":"./../semantic/16896668772390816779.xml#","docLink":"./Init/Prelude.html#Lean.MonadQuotation.addMacroScope","doc":""},{"sourceLink":"https://github.com/leanprover/lean4/blob/56cd6c1ff519d8be39f35875b5bf8719e6101c20/src/Init/Prelude.lean#L2194-L2194","name":"Lean.defaultMaxRecDepth","link":"./../semantic/17265253318533495867.xml#","docLink":"./Init/Prelude.html#Lean.defaultMaxRecDepth","doc":""},{"sourceLink":"https://github.com/leanprover/lean4/blob/56cd6c1ff519d8be39f35875b5bf8719e6101c20/src/Init/Prelude.lean#L2196-L2197","name":"Lean.maxRecDepthErrorMessage","link":"./../semantic/1885636169326841495.xml#","docLink":"./Init/Prelude.html#Lean.maxRecDepthErrorMessage","doc":""},{"sourceLink":"https://github.com/leanprover/lean4/blob/56cd6c1ff519d8be39f35875b5bf8719e6101c20/src/Init/Prelude.lean#L2201-L2202","name":"Lean.Syntax.matchesNull","link":"./../semantic/6294525874577861445.xml#","docLink":"./Init/Prelude.html#Lean.Syntax.matchesNull","doc":""},{"sourceLink":"https://github.com/leanprover/lean4/blob/56cd6c1ff519d8be39f35875b5bf8719e6101c20/src/Init/Prelude.lean#L2212-L2213","name":"Lean.Syntax.matchesIdent","link":"./../semantic/17062824155987324559.xml#","docLink":"./Init/Prelude.html#Lean.Syntax.matchesIdent","doc":"Function used for determining whether a syntax pattern `` `(id) `` is matched.\n  There are various conceivable notions of when two syntactic identifiers should be regarded as identical,\n  but semantic definitions like whether they refer to the same global name cannot be implemented without\n  context information (i.e. `MonadResolveName`). Thus in patterns we default to the structural solution\n  of comparing the identifiers' `Name` values, though we at least do so modulo macro scopes so that\n  identifiers that \"look\" the same match. This is particularly useful when dealing with identifiers that\n  do not actually refer to Lean bindings, e.g. in the `stx` pattern `` `(many($p)) ``. "},{"sourceLink":"https://github.com/leanprover/lean4/blob/56cd6c1ff519d8be39f35875b5bf8719e6101c20/src/Init/Prelude.lean#L2215-L2220","name":"Lean.Syntax.matchesLit","link":"./../semantic/1929284032898021163.xml#","docLink":"./Init/Prelude.html#Lean.Syntax.matchesLit","doc":""},{"sourceLink":"https://github.com/leanprover/lean4/blob/56cd6c1ff519d8be39f35875b5bf8719e6101c20/src/Init/Prelude.lean#L2231-L2231","name":"Lean.Macro.instNonemptyMethodsRef","link":"./../semantic/14648706713781650723.xml#","docLink":"./Init/Prelude.html#Lean.Macro.instNonemptyMethodsRef","doc":""},{"sourceLink":"https://github.com/leanprover/lean4/blob/56cd6c1ff519d8be39f35875b5bf8719e6101c20/src/Init/Prelude.lean#L2233-L2239","name":"Lean.Macro.Context","link":"./../semantic/8296840545574814151.xml#","docLink":"./Init/Prelude.html#Lean.Macro.Context","doc":""},{"sourceLink":"https://github.com/leanprover/lean4/blob/56cd6c1ff519d8be39f35875b5bf8719e6101c20/src/Init/Prelude.lean#L2241-L2243","name":"Lean.Macro.Exception","link":"./../semantic/10531692373798274253.xml#","docLink":"./Init/Prelude.html#Lean.Macro.Exception","doc":""},{"sourceLink":"https://github.com/leanprover/lean4/blob/56cd6c1ff519d8be39f35875b5bf8719e6101c20/src/Init/Prelude.lean#L2245-L2248","name":"Lean.Macr